{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-native",
    "moduleResolution": "node",
    "rootDir": "./src"
  },
  "include": ["src/**/*", "index.js"],
  "exclude": ["node_modules", "**/*.spec.ts"]
}
